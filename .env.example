# Copy to .env (gitignored). docker compose reads it automatically.

# REQUIRED: absolute path to your read-only archive on the host.
MSGBROWSE_ARCHIVE_HOST=/Users/you/Managed Files/Signal-Archive

# --- LLM endpoint (an external, OpenAI-compatible LiteLLM proxy) ---
# Must end in /v1. If your LiteLLM runs on the same host as Docker, use
# http://host.docker.internal:4000/v1.
MSGBROWSE_LLM_BASE_URL=https://litellm.example.com/v1
# The key your LiteLLM requires from clients (its master/virtual key). Leave
# empty only for a keyless local route.
MSGBROWSE_LLM_API_KEY=sk-your-litellm-key
# Model names your LiteLLM serves (model_name entries in its config).
MSGBROWSE_LLM_CHAT_MODEL=local-chat
MSGBROWSE_LLM_EMBED_MODEL=local-embed

# --- Bundled LiteLLM (only if you run `--profile bundled-llm`) ---
# Then set MSGBROWSE_LLM_BASE_URL=http://litellm:4000/v1 above, and provide any
# provider keys your litellm.config.yaml routes to (none for local Ollama).
# MSGBROWSE_LLM_API_KEY doubles as the bundled proxy's LITELLM_MASTER_KEY.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
