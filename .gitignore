# Binaries
/msgbrowse
/bin/
/dist/

# Desktop shell: Wails CLI build output and generated scaffolding — the shell
# has no JS frontend (wails.json is the only tracked Wails file); the CLI
# regenerates these on every `wails build`
/cmd/msgbrowse-desktop/build/
/cmd/msgbrowse-desktop/frontend/

# Local app data (SQLite DB, vector index, caches) — never commit
/data/
*.sqlite
*.sqlite-wal
*.sqlite-shm

# Config with secrets — only the *.example.yaml files are tracked
/config.yaml
/litellm.local.yaml
.env

# Go
*.test
*.out
/vendor/

# OS / editor cruft
.DS_Store
*.swp
.idea/
.vscode/

# Test/build scratch
/tmp/
/coverage.out

# Dev-time CSS toolchain (downloaded by `make css`)
/.tools/

# Docs site: generated MDX (rebuilt by docs-site/scripts/build-docs.js on
# every `npm run build`) and Docusaurus install/build artifacts
/docs-generated/
/docs-site/node_modules/
/docs-site/build/
/docs-site/.docusaurus/

# Transient agent worktrees (created under the repo by background agents)
/.claude/
